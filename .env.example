# Copy to .env and fill in real values — never commit .env
# See: https://help.marine.copernicus.eu/en/articles/8185600

# GitHub Personal Access Token (read access to private PMAR repo — used only at image build time)
GIT_TOKEN=your_github_pat_here

# Copernicus Marine Service credentials
COPERNICUSMARINE_SERVICE_USERNAME=your_copernicus_username
COPERNICUSMARINE_SERVICE_PASSWORD=your_copernicus_password

# Dominio pubblico del server (richiesto per HTTPS)
DOMAIN=miodominio.example.com

# Email per Let's Encrypt (notifiche scadenza certificato)
LETSENCRYPT_EMAIL=tua@email.com

# Imposta a 1 per usare il server di staging Let's Encrypt (test, nessun rate limit)
LETSENCRYPT_STAGING=0

# Optional: override gunicorn worker count (default: 4)
# GUNICORN_WORKERS=4
