# Force LF line endings for files that run inside Linux containers
*.sh        text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.py        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.conf      text eol=lf
*.cfg       text eol=lf
*.env       text eol=lf
